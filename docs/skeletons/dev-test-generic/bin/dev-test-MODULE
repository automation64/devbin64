source ./bin/dev-set &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-X_MODULE_X || exit 1

declare MY_TARGET="${*:-}"

function my_test() {
  bl64_dbg_app_show_function
  # X_TEST_PLACEHOLDER_X
  dev_X_MODULE_X_run_X_COMMAND_X
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    dev_base_log_setup "$BL64_VAR_OFF" "$DEV_ENV_X_MODULE_CAPS_X_PATH_LOGS" &&
    dev_base_lib_check_command "$DEV_ENV_X_MODULE_CAPS_X_ID" "$DEV_LIB_X_MODULE_CAPS_X_BIN" &&
    bl64_check_parameter 'MY_TARGET' &&
    dev_base_task_show_setup \
      'MY_TARGET' \
      'DEV_TEST_X_MODULE_CAPS_X_PATH_REPORT'
}

bl64_lib_script_version_set '1.0.0'
bl64_msg_help_set_about 'Test source code'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_test
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
