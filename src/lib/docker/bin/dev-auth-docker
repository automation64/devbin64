source ./bin/dev-set || { echo 'dev-set:Error: unable to load dev environment' 2>&1 && exit 1; }
source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-module-fs.bash" &&
  source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-module-txt.bash" &&
  source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-module-xsv.bash" &&
  source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-module-fmt.bash" &&
  source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-module-bsh.bash" &&
  source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-core.bash" || exit 1
source ./bin/dev-env-github &&
  source ./bin/dev-env-docker || exit 1

function my_login() {
  bl64_dbg_app_show_function
  case "$DEV_AUTH_DOCKER_TYPE" in
    'GITHUB')
      "$DEV_LIB_GITHUB_BIN" auth token |
        "$DEV_LIB_DOCKER_BIN" login \
          "$DEV_AUTH_DOCKER_USER" "$DEV_AUTH_DOCKER_REGISTRY"
      ;;
    *)
      "$DEV_LIB_DOCKER_BIN" login \
        "$DEV_AUTH_DOCKER_USER" "$DEV_AUTH_DOCKER_PASSWORD" "$DEV_AUTH_DOCKER_REGISTRY"
      ;;
  esac
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_bin64_task_initialize &&
    bl64_check_export 'DEV_AUTH_DOCKER_USER' &&
    bl64_check_export 'DEV_AUTH_DOCKER_REGISTRY' &&
    bl64_check_command "$DEV_LIB_DOCKER_BIN" ||
    return $?

  if [[ "$DEV_AUTH_DOCKER_TYPE" == 'GITHUB' ]]; then
    bl64_check_command "$DEV_LIB_GITHUB_BIN"
  else
    bl64_check_export 'DEV_AUTH_DOCKER_PASSWORD'
  fi || return $?

  dev_bin64_task_show_setup \
    'DEV_AUTH_DOCKER_TYPE' \
    'DEV_AUTH_DOCKER_USER' \
    'DEV_AUTH_DOCKER_REGISTRY'
}

bl64_lib_script_version_set '1.0.0'
bl64_msg_help_about_set 'Login to Container Registry'
dev_bin64_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_login
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
