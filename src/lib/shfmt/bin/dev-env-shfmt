#
# Module variables
#
# * Shared internal variables for module tasks
#

# shellcheck disable=SC2154
{
  # Env / ShFmt / Module environment definition version
  export DEV_ENV_SHFMT_ID='shfmt'
  export DEV_ENV_SHFMT_VERSION='1.0.0'
  # Env / ShFmt / Log path
  export DEV_ENV_SHFMT_PATH_LOGS="${DEV_PATH_LOGS}/${DEV_ENV_SHFMT_ID}"

  # Lib / ShFmt / Installer
  export DEV_LIB_SHFMT_INSTALLER="${DEV_LIB_INSTALLER64_TARGET}/install-shfmt"
  # Lib / ShFmt / Skip installation?
  export DEV_LIB_SHFMT_SKIP='YES'
  # Lib / ShFmt / Target
  export DEV_LIB_SHFMT_TARGET="${DEV_PATH_LIB}/${DEV_ENV_SHFMT_ID}"

  # Lint / ShFmt / Format
  export DEV_LINT_SHFMT_FORMAT='txt'
  # Lint / ShFmt / Report
  export DEV_LINT_SHFMT_PATH_REPORT="${DEV_ENV_SHFMT_PATH_LOGS}/${DEV_ENV_SHFMT_ID}-lint.${DEV_LINT_SHFMT_FORMAT}"
}

#
# Module parameters
#
# * Use .dev.env file to override values
#

# shellcheck disable=SC2154
{
  # Lint / ShFmt / Target
  export DEV_LINT_SHFMT_TARGET="${DEV_LINT_SHFMT_TARGET:-${DEV_PATH_SRC}}"
}

#
# Locals
#
# * Use .local.env file or CICD variables to override values
#

# shellcheck disable=SC2154
{
  # Lib / ShFmt / Command
  export DEV_LIB_SHFMT_BIN="${DEV_LIB_SHFMT_BIN:-}"
  if [[ -z "$DEV_LIB_SHFMT_BIN" ]]; then
    DEV_LIB_SHFMT_BIN="$(dev_bin64_lib_locate 'shfmt')"
    if [[ -z "$DEV_LIB_SHFMT_BIN" ]]; then
      DEV_LIB_SHFMT_BIN="${DEV_LIB_SHFMT_TARGET}/shfmt"
      if [[ ! -x "${DEV_LIB_SHFMT_BIN}" ]]; then
        DEV_LIB_SHFMT_SKIP='NO'
      fi
    else
      DEV_LIB_SHFMT_TARGET="$(dev_bin64_lib_basename "$DEV_LIB_SHFMT_BIN")"
    fi
  fi
}
