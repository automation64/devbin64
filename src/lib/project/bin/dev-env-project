#
# Module variables
#
# * Shared internal variables for module tasks
#

# shellcheck disable=SC2154
{
  # Env / Project / Module environment definition version
  export DEV_ENV_PROJECT_ID='project'
  export DEV_ENV_PROJECT_VERSION='1.0.0'
  # Env / Project / Container path for project mounts
  export DEV_ENV_PROJECT_CONTAINER_PATH_SRC='/source'
  export DEV_ENV_PROJECT_CONTAINER_PATH_TEST='/test'
  export DEV_ENV_PROJECT_CONTAINER_PATH_ROOT='/project'
  export DEV_ENV_PROJECT_CONTAINER_PATH_BUILD='/project/build'
  export DEV_ENV_PROJECT_CONTAINER_PATH_LIB='/project/lib'
  export DEV_ENV_PROJECT_CONTAINER_PATH_TMP='/project/tmp'
  # Env / Project / Flag for marking container environment
  export DEV_ENV_PROJECT_CONTAINER_ENVIRONMENT="${DEV_ENV_PROJECT_CONTAINER_ENVIRONMENT:-OFF}"
}

#
# Module parameters
#
# * Use .dev.env file to override values
#

# shellcheck disable=SC2154
{
  # Env / Project / Registry for lab and testing containers
  export DEV_ENV_PROJECT_REGISTRY="${DEV_ENV_PROJECT_REGISTRY:-ghcr.io/automation64}"

  # Lab / Project / Default image
  export DEV_LAB_PROJECT_CONTAINER="${DEV_LAB_PROJECT_CONTAINER:-bash-test/alpine-3-bash-test}"
}
