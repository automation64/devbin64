#
# Module variables
#
# * Shared internal variables for module tasks
#

# shellcheck disable=SC2154
{
  # Env / Nuclei / Module environment definition version
  export DEV_ENV_NUCLEI_ID='nuclei'
  export DEV_ENV_NUCLEI_VERSION='1.0.0'
  # Env / Nuclei / Log path
  export DEV_ENV_NUCLEI_PATH_LOGS="${DEV_PATH_LOGS}/${DEV_ENV_NUCLEI_ID}"

  # Lib / Nuclei / Installer
  export DEV_LIB_NUCLEI_INSTALLER="${DEV_LIB_INSTALLER64_TARGET}/install-nuclei"
  # Lib / Nuclei / Skip installation?
  export DEV_LIB_NUCLEI_SKIP='YES'
  # Lib / Nuclei / Target
  export DEV_LIB_NUCLEI_TARGET="${DEV_PATH_LIB}/${DEV_ENV_NUCLEI_ID}"
  # Lib / Nuclei / Configuration
  export DEV_LIB_NUCLEI_CONFIG="${DEV_PATH_ROOT}/.nuclei.yaml"

  # DAST / Nuclei / Format
  export DEV_DAST_NUCLEI_FORMAT='sarif'
  # DAST / Nuclei / Report
  export DEV_DAST_NUCLEI_PATH_REPORT="${DEV_ENV_NUCLEI_PATH_LOGS}/${DEV_ENV_NUCLEI_ID}-dast.${DEV_DAST_NUCLEI_FORMAT}"
}

#
# Module parameters
#
# * Use .dev.env file to override values
#

# shellcheck disable=SC2154
{
  # DAST / Nuclei / Target
  export DEV_DAST_NUCLEI_TARGET="${DEV_DAST_NUCLEI_TARGET:-}"
}

#
# Locals
#
# * Use .local.env file or CICD variables to override values
#

# shellcheck disable=SC2154
{
  # Lib / Nuclei / Command
  export DEV_LIB_NUCLEI_BIN="${DEV_LIB_NUCLEI_BIN:-}"
  if [[ -z "$DEV_LIB_NUCLEI_BIN" ]]; then
    DEV_LIB_NUCLEI_BIN="$(dev_bin64_lib_locate 'nuclei')"
    if [[ -z "$DEV_LIB_NUCLEI_BIN" ]]; then
      DEV_LIB_NUCLEI_BIN="${DEV_LIB_NUCLEI_TARGET}/nuclei"
      if [[ ! -x "${DEV_LIB_NUCLEI_BIN}" ]]; then
        DEV_LIB_NUCLEI_SKIP='NO'
      fi
    else
      DEV_LIB_NUCLEI_TARGET="$(dev_bin64_lib_basename "$DEV_LIB_NUCLEI_BIN")"
    fi
  fi
}
