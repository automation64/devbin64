source ./bin/dev-set &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-kubelinter || exit 1

declare MY_TARGET="${*:-$DEV_BASE_SRC}"

function my_lint_local() {
  bl64_dbg_app_show_function "$@"
  local target="$1"
  dev_kubelinter_run_kubelinter \
    lint \
    --format "$DEV_LINT_KUBELINTER_FORMAT" \
    "$target" >"$DEV_LINT_KUBELINTER_PATH_REPORT"
}

function my_lint_container() {
  bl64_dbg_app_show_function "$@"
  local target="$1"
  dev_kubelinter_run_container \
    "${DEV_LINT_KUBELINTER_CONTAINER_ENTRYPOINT}" \
    "${DEV_ENV_KUBELINTER_REGISTRY}/${DEV_LINT_KUBELINTER_CONTAINER}" \
    lint \
    --format "$DEV_LINT_KUBELINTER_FORMAT" \
    "$target" >"$DEV_LINT_KUBELINTER_PATH_REPORT"
}

function my_lint() {
  bl64_dbg_app_show_function
  local current=''

  for current in $MY_TARGET; do
    bl64_msg_show_phase "lint K8S Manifest target (${current})"
    if dev_base_lib_is_mode_container; then
      my_lint_container "$current"
    else
      my_lint_local "$current"
    fi
  done
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    dev_base_log_setup "$BL64_VAR_OFF" "$DEV_ENV_KUBELINTER_PATH_LOGS" &&
    dev_base_lib_setup_container "$DEV_ENV_KUBELINTER_ID" "$DEV_LIB_KUBELINTER_BIN" &&
    dev_base_task_show_setup \
      'DEV_LINT_KUBELINTER_PATH_REPORT' \
      'MY_TARGET'
}

bl64_lib_script_version_set '3.0.0'
bl64_msg_help_set_about 'Lint K8S manifest source code'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_lint
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
