source ./bin/dev-set &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-go &&
  source ./bin/dev-env-gosec || exit 1

declare MY_TARGET="${1:-${DEV_SAST_GOSEC_TARGET}}"

function my_sast() {
  bl64_dbg_app_show_function
  PATH="${PATH}:${DEV_LIB_GO_TARGET}"
  "$DEV_LIB_GOSEC_BIN" \
    -sort \
    -stdout \
    -verbose 'text' \
    -fmt "$DEV_SAST_GOSEC_FORMAT" \
    -out "$DEV_SAST_GOSEC_PATH_REPORT" \
    "${MY_TARGET}/..."
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    dev_base_log_setup "$BL64_VAR_ON" "$DEV_ENV_GOSEC_PATH_LOGS" &&
    bl64_check_command "$DEV_LIB_GO_BIN" &&
    bl64_check_command "$DEV_LIB_GOSEC_BIN" &&
    dev_base_task_show_setup \
      'MY_TARGET' \
      'DEV_SAST_GOSEC_PATH_REPORT'
}

bl64_lib_script_version_set '1.1.0'
bl64_msg_help_set_about 'Static test source code security'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_sast
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
