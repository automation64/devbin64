#
# Module variables
#
# * Shared internal variables for module tasks
#

# shellcheck disable=SC2154
{
  # Env / Kustomize / Module environment definition version
  export DEV_ENV_KUSTOMIZE_ID='kustomize'
  export DEV_ENV_KUSTOMIZE_VERSION='1.1.0'

  # Test / Kustomize / Format
  export DEV_TEST_KUSTOMIZE_FORMAT='log'
}

#
# Module parameters
#
# * Use .dev.env file to override values
#

# shellcheck disable=SC2154
{
  # Env / Kustomize / Log path
  export DEV_ENV_KUSTOMIZE_PATH_LOGS="${DEV_ENV_KUSTOMIZE_PATH_LOGS:-${DEV_PATH_PROF_LOGS}/${DEV_ENV_KUSTOMIZE_ID}}"

  # Test / Kustomize / Report
  export DEV_TEST_KUSTOMIZE_PATH_REPORT="${DEV_ENV_KUSTOMIZE_PATH_LOGS}/${DEV_ENV_KUSTOMIZE_ID}-test.${DEV_TEST_KUSTOMIZE_FORMAT}"

  # Deploy / Kustomize / Log file path
  export DEV_DEPLOY_KUSTOMIZE_PATH_LOG="${DEV_ENV_KUSTOMIZE_PATH_LOGS}/${DEV_ENV_KUSTOMIZE_ID}-deploy.log"

  # Remove / Kustomize / Log file path
  export DEV_REMOVE_KUSTOMIZE_PATH_LOG="${DEV_ENV_KUSTOMIZE_PATH_LOGS}/${DEV_ENV_KUSTOMIZE_ID}-remove.log"
}
