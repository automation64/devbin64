source ./bin/dev-set &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-hadolint || exit 1

declare MY_TARGET="${*:-$DEV_LINT_HADOLINT_SOURCE}"

function my_lint() {
  bl64_dbg_app_show_function
  local target=''
  local current=''

  if [[ -d "$MY_TARGET" ]]; then
    target="$(bl64_fs_file_search "$MY_TARGET" 'Dockerfile')" ||
      return $?
  fi
  for current in $target; do
    bl64_msg_show_phase "lint target: ${current}"
    if dev_base_lib_is_mode_container; then
      my_lint_container "$current"
    else
      my_lint_local "$current"
    fi
  done
}

function my_lint_container() {
  bl64_dbg_app_show_function "$@"
  local target="$1"
  # shellcheck disable=SC2086
  bl64_cnt_run \
    $BL64_CNT_SET_RM \
    $BL64_CNT_SET_TTY \
    --workdir="$DEV_ENV_HADOLINT_CONTAINER_PATH_ROOT" \
    --mount "type=bind,source=${DEV_PATH_ROOT},target=${DEV_ENV_HADOLINT_CONTAINER_PATH_ROOT},readonly" \
    --entrypoint="${DEV_LINT_HADOLINT_CONTAINER_ENTRYPOINT}" \
    "${DEV_ENV_HADOLINT_REGISTRY}/${DEV_LINT_HADOLINT_CONTAINER}" \
    --config "${DEV_ENV_HADOLINT_CONTAINER_PATH_ROOT}/${DEV_LIB_HADOLINT_CFG}" \
    "$target"
}

function my_lint_local() {
  bl64_dbg_app_show_function "$@"
  local target="$1"
  "$DEV_LIB_HADOLINT_BIN" \
    --config "${DEV_PATH_ROOT}/${DEV_LIB_HADOLINT_CFG}" \
    "$target"
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    dev_base_lib_setup_container "$DEV_ENV_HADOLINT_ID" "$DEV_LIB_HADOLINT_BIN" &&
    dev_base_task_show_setup \
      'MY_TARGET'
}

bl64_lib_script_version_set '4.1.0'
bl64_msg_help_set_about 'Lint source code'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_lint
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
