source ./bin/dev-set &&
  source ./bin/dev-source-ansible &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-ansible || exit 1

declare MY_TARGET="${*:-${DEV_PACK_ANSIBLE_CATALOG_COLLECTIONS}}"

function my_pack() {
  bl64_dbg_app_show_function
  local pack_current=''

  cd "$DEV_PACK_ANSIBLE_PATH_TARGET" ||
    return $?

  for pack_current in $MY_TARGET; do
    bl64_msg_show_phase "pack Ansible Collection (${pack_current})"
    bl64_ans_run_ansible_galaxy \
      collection build "${DEV_PACK_ANSIBLE_BASE_COLLECTIONS}/${pack_current}" ||
      return $?
  done
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    dev_base_pack_setup "$DEV_PACK_ANSIBLE_PATH_TARGET" &&
    bl64_check_parameter 'MY_TARGET' &&
    bl64_check_export 'DEV_PACK_ANSIBLE_GALAXY_NAMESPACE' &&
    bl64_check_directory "$DEV_PACK_ANSIBLE_BASE_COLLECTIONS" &&
    bl64_ans_setup "$BL64_VAR_DEFAULT" "$DEV_LIB_ANSIBLE_CONFIG" &&
    dev_base_task_show_setup \
      'DEV_LIB_ANSIBLE_CONFIG' \
      'DEV_PACK_ANSIBLE_PATH_TARGET' \
      'DEV_PACK_ANSIBLE_GALAXY_NAMESPACE' \
      'DEV_PACK_ANSIBLE_BASE_COLLECTIONS' \
      'MY_TARGET'
}

bl64_lib_script_version_set '4.0.0'
bl64_msg_help_set_about 'Pack application for release'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_pack
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
