source ./bin/dev-set &&
  source ./bin/dev-source-ansible &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-ansible || exit 1

declare MY_PLAYBOOK="${1:-}"

function my_deploy() {
  bl64_dbg_app_show_function
  bl64_msg_show_phase 'Deploy application'
  dev_ansible_run_playbook \
    "$MY_PLAYBOOK" >"$DEV_DEPLOY_ANSIBLE_PATH_LOG" 2>&1
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    dev_ansible_setup &&
    dev_base_log_setup "$BL64_VAR_OFF" "$DEV_ENV_ANSIBLE_PATH_LOGS" &&
    bl64_check_parameter 'MY_PLAYBOOK' &&
    bl64_check_file "$MY_PLAYBOOK" &&
    dev_base_task_show_setup \
      'DEV_LIB_ANSIBLE_CONFIG' \
      'DEV_LIB_ANSIBLE_INVENTORY_SHARED' \
      'DEV_LIB_ANSIBLE_INVENTORY_MAIN' \
      'DEV_DEPLOY_ANSIBLE_PATH_LOG' \
      'MY_PLAYBOOK'
}

bl64_lib_script_version_set '2.0.0'
bl64_msg_help_set_about 'Run deployment scripts'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_deploy
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
