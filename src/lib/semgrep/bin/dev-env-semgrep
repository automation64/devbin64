#
# Module variables
#
# * Shared internal variables for module tasks
#

# shellcheck disable=SC2154
{
  # Env / Semgrep / Module environment definition version
  export DEV_ENV_SEMGREP_ID='semgrep'
  export DEV_ENV_SEMGREP_VERSION='1.0.0'
  # Env / Semgrep / Log path
  export DEV_ENV_SEMGREP_PATH_LOGS="${DEV_PATH_LOGS}/${DEV_ENV_SEMGREP_ID}"

  # Lib / Semgrep / Installer
  export DEV_LIB_SEMGREP_INSTALLER="${DEV_LIB_INSTALLER64_TARGET}/install-semgrep"
  # Lib / Semgrep / Skip installation?
  export DEV_LIB_SEMGREP_SKIP='YES'
  # Lib / Semgrep / Target
  export DEV_LIB_SEMGREP_TARGET="${DEV_PATH_LIB}/${DEV_ENV_SEMGREP_ID}"

  # SAST / Semgrep / Format
  export DEV_SAST_SEMGREP_FORMAT='sarif'
  # SAST / Semgrep / Report
  export DEV_SAST_SEMGREP_PATH_REPORT="${DEV_ENV_SEMGREP_PATH_LOGS}/${DEV_ENV_SEMGREP_ID}-sast.${DEV_SAST_SEMGREP_FORMAT}"
}

#
# Module parameters
#
# * Use .dev.env file to override values
#

# shellcheck disable=SC2154
{
  # SAST / Semgrep / Target
  export DEV_SAST_SEMGREP_TARGET="${DEV_SAST_SEMGREP_TARGET:-}"
  # SAST / Semgrep / Severity
  export DEV_SAST_SEMGREP_SEVERITY="${DEV_SAST_SEMGREP_SEVERITY:-ERROR}"
}

#
# Locals
#
# * Use .local.env file or CICD variables to override values
#

# shellcheck disable=SC2154
{
  export DEV_LIB_SEMGREP_BIN="${DEV_LIB_SEMGREP_BIN:-}"
  if [[ -z "$DEV_LIB_SEMGREP_BIN" ]]; then
    DEV_LIB_SEMGREP_BIN="$(dev_bin64_lib_locate 'semgrep')"
    if [[ -z "$DEV_LIB_SEMGREP_BIN" ]]; then
      DEV_LIB_SEMGREP_BIN="${DEV_LIB_SEMGREP_TARGET}/semgrep"
      if [[ ! -x "${DEV_LIB_SEMGREP_BIN}" ]]; then
        DEV_LIB_SEMGREP_SKIP='NO'
      fi
    else
      DEV_LIB_SEMGREP_TARGET="$(dev_bin64_lib_basename "$DEV_LIB_SEMGREP_BIN")"
    fi
  fi
}
