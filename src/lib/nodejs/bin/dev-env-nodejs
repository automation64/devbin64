#
# Module variables
#
# * Shared internal variables for module tasks
#

# shellcheck disable=SC2154
{
  # Env / NodeJS / Module environment definition version
  export DEV_ENV_NODEJS_ID='nodejs'
  export DEV_ENV_NODEJS_VERSION='1.1.0'

  # Env / NodeJS / Log path
  export DEV_ENV_NODEJS_PATH_LOGS="${DEV_PATH_LOGS}/${DEV_ENV_NODEJS_ID}"

  # Lib / NodeJS / Installer
  export DEV_LIB_NODEJS_INSTALLER="${DEV_LIB_INSTALLER64_TARGET}/install-nodejs"
  # Lib / NodeJS / Skip installation?
  export DEV_LIB_NODEJS_SKIP='YES'
  # Lib / NodeJS / Target
  export DEV_LIB_NODEJS_TARGET="${DEV_PATH_LIB}/${DEV_ENV_NODEJS_ID}"
  # Lib / NodeJS / NPM cache
  export DEV_LIB_NODEJS_PATH_CACHE="${DEV_PATH_TMP}/npm-cache"

  # Build / NodeJS / Target
  export DEV_BUILD_NODEJS_PATH_TARGET="${DEV_PATH_BUILD_PREPARE}/${DEV_ENV_NODEJS_ID}"

  # SBOM / NodeJS / Format
  export DEV_SBOM_NODEJS_FORMAT='spdx'
  # SBOM / NodeJS / Report
  export DEV_SBOM_NODEJS_PATH_REPORT="${DEV_ENV_NODEJS_PATH_LOGS}/${DEV_ENV_NODEJS_ID}-sbom.${DEV_SBOM_NODEJS_FORMAT}"

  # SCA / NodeJS / Format
  export DEV_SCA_NODEJS_FORMAT='json'
  # SCA / NodeJS / Report
  export DEV_SCA_NODEJS_PATH_REPORT="${DEV_ENV_NODEJS_PATH_LOGS}/${DEV_ENV_NODEJS_ID}-sca.${DEV_SCA_NODEJS_FORMAT}"
}

#
# Module parameters
#
# * Use .dev.env file to override values
#

# shellcheck disable=SC2154
{
  # Lib / NodeJS / Version
  export DEV_LIB_NODEJS_VERSION="${DEV_LIB_NODEJS_VERSION:-latest}"

  # Build / NodeJS / Source
  export DEV_BUILD_NODEJS_PATH_SOURCE="${DEV_BUILD_NODEJS_PATH_SOURCE:-$DEV_PATH_SRC}"

  # Build / NodeJS / NPM package and lock file location
  export DEV_BUILD_NODEJS_PATH_PACKAGE="${DEV_BUILD_NODEJS_PATH_PACKAGE:-$DEV_PATH_ROOT}"

  # SAST / NodeJS / Severity
  export DEV_SCA_NODEJS_SEVERITY="${DEV_SCA_NODEJS_SEVERITY:-high}"

  # Run / NodeJS / Entrypoint
  export DEV_RUN_NODEJS_MAIN="${DEV_RUN_NODEJS_MAIN:-}"
}

#
# Locals
#
# * Use .local.env file or CICD variables to override values
#

# shellcheck disable=SC2154
{
  # Lib / NodeJS / Command
  export DEV_LIB_NODEJS_BIN_NPM="${DEV_LIB_NODEJS_BIN_NPM:-}"
  export DEV_LIB_NODEJS_BIN_NODE="${DEV_LIB_NODEJS_BIN_NODE:-}"
  if [[ -z "$DEV_LIB_NODEJS_BIN_NPM" ]]; then
    DEV_LIB_NODEJS_BIN_NPM="$(dev_bin64_lib_locate 'npm')"
    DEV_LIB_NODEJS_BIN_NODE="$(dev_bin64_lib_locate 'node')"
    if [[ -z "$DEV_LIB_NODEJS_BIN_NPM" ]]; then
      DEV_LIB_NODEJS_BIN_NPM="${DEV_LIB_NODEJS_TARGET}/npm"
      DEV_LIB_NODEJS_BIN_NODE="${DEV_LIB_NODEJS_TARGET}/node"
      if [[ ! -x "${DEV_LIB_NODEJS_BIN_NPM}" ]]; then
        DEV_LIB_NODEJS_SKIP='NO'
      fi
    else
      DEV_LIB_NODEJS_TARGET="$(dev_bin64_lib_basename "$DEV_LIB_NODEJS_BIN_NPM")"
    fi
  fi
}
