source ./bin/dev-set &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-nodejs || exit 1

function my_build() {
  bl64_dbg_app_show_function

  bl64_msg_show_task 'Populate staging area with source code'
  bl64_fs_path_copy "$BL64_VAR_DEFAULT" "$BL64_VAR_DEFAULT" "$BL64_VAR_DEFAULT" "$BL64_VAR_DEFAULT" \
    "$DEV_BUILD_NODEJS_PATH_TARGET" \
    "$DEV_BUILD_NODEJS_PATH_SOURCE" ||
    return $?

  bl64_msg_show_task 'Populate staging area with NPM package definitions'
  bl64_fs_path_copy "$BL64_VAR_DEFAULT" "$BL64_VAR_DEFAULT" "$BL64_VAR_DEFAULT" "$BL64_VAR_DEFAULT" \
    "$DEV_BUILD_NODEJS_PATH_TARGET" \
    "${DEV_BUILD_NODEJS_PATH_PACKAGE}/package.json" \
    "${DEV_BUILD_NODEJS_PATH_PACKAGE}/package-lock.json" ||
    return $?

  bl64_msg_show_task 'Create project environment'
  cd "$DEV_BUILD_NODEJS_PATH_TARGET" &&
    "$DEV_LIB_NODEJS_BIN_NPM" \
      --omit=dev \
      --global=false \
      --audit=false \
      --foreground-scripts \
      --fund=false \
      ci
}

function my_initialize() {
  bl64_dbg_app_show_function
  dev_base_task_initialize &&
    dev_base_build_setup "$DEV_BUILD_NODEJS_PATH_TARGET" &&
    dev_base_task_show_setup \
      'DEV_BUILD_NODEJS_PATH_SOURCE' \
      'DEV_BUILD_NODEJS_PATH_TARGET'
}

bl64_lib_script_version_set '1.1.0'
bl64_msg_help_set_about 'Build application in staging area'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_build
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
