#
# Module variables
#
# * Shared internal variables for module tasks
#

# shellcheck disable=SC2154
{
  # Env / TFLint / Module environment definition version
  export DEV_ENV_TFLINT_ID='tflint'
  export DEV_ENV_TFLINT_VERSION='1.4.0'

  # Lib / TFLint / Installer
  export DEV_LIB_TFLINT_INSTALLER="${DEV_LIB_INSTALLER64_TARGET}/install-tflint"
  # Lib / TFLint / Skip installation?
  export DEV_LIB_TFLINT_SKIP='YES'
  # Lib / TFLint / Target
  export DEV_LIB_TFLINT_TARGET="${DEV_PATH_LIB}/${DEV_ENV_TFLINT_ID}"
  # Lib / TFLint / Configuration
  export DEV_LIB_TFLINT_CFG="${DEV_PATH_ROOT}/.tflint.hcl"

  # Lint / TFLint / Format
  export DEV_LINT_TFLINT_FORMAT='sarif'
}

#
# Module parameters
#
# * Use .dev.env file to override values
#

# shellcheck disable=SC2154
{
  # Env / TFLint / Log path
  export DEV_ENV_TFLINT_PATH_LOGS="${DEV_ENV_TFLINT_PATH_LOGS:-${DEV_PATH_PROF_LOGS}/${DEV_ENV_TFLINT_ID}}"

  # Lint / TFLint / Target
  export DEV_LINT_TFLINT_TARGET="${DEV_LINT_TFLINT_TARGET:-${DEV_PATH_SRC}}"
  # Lint / TFLint / Report
  export DEV_LINT_TFLINT_PATH_REPORT="${DEV_ENV_TFLINT_PATH_LOGS}/${DEV_ENV_TFLINT_ID}-lint.${DEV_LINT_TFLINT_FORMAT}"
}

#
# Locals
#
# * Use .local.env file or CICD variables to override values
#

# shellcheck disable=SC2154
{
  # Lib / TFLint / Command
  export DEV_LIB_TFLINT_BIN="${DEV_LIB_TFLINT_BIN:-}"
  if [[ -z "$DEV_LIB_TFLINT_BIN" ]]; then
    DEV_LIB_TFLINT_BIN="$(dev_bin64_lib_locate 'tflint')"
    if [[ -z "$DEV_LIB_TFLINT_BIN" ]]; then
      DEV_LIB_TFLINT_BIN="${DEV_LIB_TFLINT_TARGET}/tflint"
      if [[ ! -x "${DEV_LIB_TFLINT_BIN}" ]]; then
        DEV_LIB_TFLINT_SKIP='NO'
      fi
    else
      DEV_LIB_TFLINT_TARGET="$(dev_bin64_lib_basename "$DEV_LIB_TFLINT_BIN")"
    fi
  fi
}

#
# Module functions
#
# * Shared internal functions for module tasks
#

function dev_tflint_run_tflint() {
  bl64_dbg_app_show_function "$@"
  bl64_dbg_lib_trace_start
  "$DEV_LIB_TFLINT_BIN" \
    --no-color \
    --config "$DEV_LIB_TFLINT_CFG" \
    "$@"
  bl64_dbg_lib_trace_stop
}
