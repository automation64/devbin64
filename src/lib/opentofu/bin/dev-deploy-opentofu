source ./bin/dev-set || { echo 'dev-set:Error: unable to load dev environment' 2>&1 && exit 1; }
source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-module-tf.bash" &&
  source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-module-fs.bash" &&
  source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-module-txt.bash" &&
  source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-module-xsv.bash" &&
  source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-module-fmt.bash" &&
  source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-module-bsh.bash" &&
  source "${DEV_LIB_BASHLIB64_TARGET}/bashlib64-core.bash" || exit 1
source ./bin/dev-env-opentofu || exit 1

declare MY_STAGING="${1:-${DEV_BUILD_OPENTOFU_STAGING}}"
declare MY_LOGS="${2:-${DEV_ENV_OPENTOFU_PATH_LOGS}}"

function my_deploy() {
  bl64_dbg_app_show_function

  bl64_msg_show_task 'Prepare log store'
  bl64_fs_path_remove "$MY_LOGS"
  bl64_fs_dir_create \
    "$BL64_VAR_DEFAULT" "$BL64_VAR_DEFAULT" "$BL64_VAR_DEFAULT" "$MY_LOGS" ||
    return $?

  bl64_msg_show_task 'Run apply phase'
  cd "$DEV_BUILD_OPENTOFU_STAGING" &&
    bl64_tf_run_tofu \
      apply \
      -concise \
      -input=false \
      -auto-approve \
      "${DEV_TEST_OPENTOFU_PATH_PLAN}"
}

function my_initialize() {
  bl64_dbg_app_show_function
  DEV_ENV_OPENTOFU_PATH_LOGS="$MY_LOGS"
  DEV_BUILD_OPENTOFU_STAGING="$MY_STAGING"
  DEV_DEPLOY_OPENTOFU_PATH_LOG="${DEV_ENV_OPENTOFU_PATH_LOGS}/${DEV_DEPLOY_OPENTOFU_FILE_LOG}"
  DEV_TEST_OPENTOFU_PATH_PLAN="${DEV_BUILD_OPENTOFU_STAGING}/${DEV_TEST_OPENTOFU_FILE_PLAN}"
  dev_bin64_task_initialize &&
    if bl64_lib_flag_is_enabled "$DEV_DEPLOY_OPENTOFU_GUARDRAIL_ENABLED"; then
      bl64_msg_show_fatal 'Guardrail is enabled, cancelling deployment'
      return "$BL64_LIB_ERROR_TASK_REQUIREMENTS"
    fi
  bl64_lib_script_minver_check "$DEV_ENV_OPENTOFU_VERSION_BL64" &&
    bl64_check_directory "$DEV_BUILD_OPENTOFU_STAGING" &&
    bl64_check_file "$DEV_TEST_OPENTOFU_PATH_PLAN" &&
    dev_bin64_log_setup "$BL64_VAR_OFF" "$DEV_ENV_OPENTOFU_PATH_LOGS" &&
    bl64_tf_setup "$(bl64_fmt_path_get_dirname "$DEV_LIB_OPENTOFU_BIN")" &&
    bl64_tf_log_set "$DEV_DEPLOY_OPENTOFU_PATH_LOG" "$DEV_LIB_OPENTOFU_SET_LOG" &&
    dev_bin64_task_show_setup \
      'DEV_BUILD_OPENTOFU_STAGING' \
      'DEV_ENV_OPENTOFU_PATH_LOGS' \
      'DEV_DEPLOY_OPENTOFU_PATH_LOG' \
      'DEV_TEST_OPENTOFU_PATH_PLAN' \
      'DEV_LIB_OPENTOFU_SET_LOG' &&
    bl64_msg_show_warning 'Guardrail is disabled. The deployment will proceed without further confirmation (DEV_DEPLOY_OPENTOFU_GUARDRAIL_ENABLED=NO)'
}

bl64_lib_script_version_set '4.0.0'
bl64_msg_help_about_set 'Deploy infrastructure'
dev_bin64_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_deploy
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
