source ./bin/dev-set &&
  source ./bin/dev-source-opentofu &&
  source ./bin/dev-source-base &&
  source ./bin/dev-env-opentofu || exit 1

declare MY_STAGING="${1:-${DEV_BUILD_OPENTOFU_STAGING}}"

function my_prepare() {
  bl64_dbg_app_show_function

  if [[ -d "$DEV_TEST_OPENTOFU_CASES_PLAN" ]]; then
    bl64_msg_show_task 'Prepare test cases'
    bl64_fs_path_merge \
      "$DEV_TEST_OPENTOFU_CASES_PLAN" \
      "$DEV_BUILD_OPENTOFU_STAGING"
  fi

  if [[ -d "$DEV_TEST_OPENTOFU_CASES_TEST" ]]; then
    bl64_msg_show_task 'Prepare test cases'
    bl64_fs_path_merge \
      "$DEV_TEST_OPENTOFU_CASES_TEST" \
      "$DEV_BUILD_OPENTOFU_STAGING"
  fi
}

function my_plan() {
  bl64_dbg_app_show_function
  bl64_msg_show_task 'Remove obsolete plan'
  bl64_fs_path_remove \
    "$DEV_TEST_OPENTOFU_PATH_PLAN" \
    "$DEV_REMOVE_OPENTOFU_PATH_PLAN"

  bl64_msg_show_task 'Run plan phase'
  cd "$DEV_BUILD_OPENTOFU_STAGING" &&
    bl64_tf_run_tofu \
      plan \
      -no-color \
      -concise \
      -input=false \
      -out="$DEV_TEST_OPENTOFU_PATH_PLAN" >"$DEV_TEST_OPENTOFU_PATH_STDOUT" 2>"$DEV_TEST_OPENTOFU_PATH_STDERR"
}

function my_test() {
  bl64_dbg_app_show_function
  bl64_msg_show_task 'Run test phase'
  cd "$DEV_BUILD_OPENTOFU_STAGING" &&
    bl64_tf_run_tofu \
      test \
      -no-color >>"$DEV_TEST_OPENTOFU_PATH_STDOUT" 2>>"$DEV_TEST_OPENTOFU_PATH_STDERR"
}

function my_initialize() {
  bl64_dbg_app_show_function
  DEV_BUILD_OPENTOFU_STAGING="$MY_STAGING"
  DEV_TEST_OPENTOFU_PATH_PLAN="${DEV_BUILD_OPENTOFU_STAGING}/${DEV_TEST_OPENTOFU_FILE_PLAN}"
  dev_base_task_initialize &&
    bl64_lib_script_minver_check "$DEV_LIB_OPENTOFU_REQUIRED_BASHLIB64" &&
    bl64_check_directory "$DEV_BUILD_OPENTOFU_STAGING" &&
    dev_base_log_setup "$BL64_VAR_ON" "$DEV_ENV_OPENTOFU_PATH_LOGS" &&
    bl64_tf_setup "$(bl64_fmt_path_get_dirname "$DEV_LIB_OPENTOFU_BIN")" &&
    bl64_tf_set_logging "$DEV_TEST_OPENTOFU_PATH_LOG" "$DEV_LIB_OPENTOFU_SET_LOG" &&
    dev_base_task_show_setup \
      'DEV_BUILD_OPENTOFU_STAGING' \
      'DEV_TEST_OPENTOFU_CASES_PLAN' \
      'DEV_TEST_OPENTOFU_PATH_LOG' \
      'DEV_TEST_OPENTOFU_PATH_STDOUT' \
      'DEV_TEST_OPENTOFU_PATH_STDERR' \
      'DEV_TEST_OPENTOFU_PATH_PLAN'
}

bl64_lib_script_version_set '4.0.0'
bl64_msg_help_set_about 'Test source code with tofu plan'
dev_base_initialize && my_initialize || exit $?

bl64_msg_show_batch_start "$BL64_SCRIPT_ID"
my_prepare &&
  my_plan &&
  my_test
bl64_msg_show_batch_finish $? "$BL64_SCRIPT_ID"
