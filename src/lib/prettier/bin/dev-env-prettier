#
# Module variables
#
# * Shared internal variables for module tasks
#

# shellcheck disable=SC2154
{
  # Env / Prettier / Module environment definition version
  export DEV_ENV_PRETTIER_ID='prettier'
  export DEV_ENV_PRETTIER_VERSION='1.0.0'
  # Env / Prettier / Log path
  export DEV_ENV_PRETTIER_PATH_LOGS="${DEV_PATH_LOGS}/${DEV_ENV_PRETTIER_ID}"

  # Lib / Prettier / Installer
  export DEV_LIB_PRETTIER_INSTALLER="${DEV_LIB_INSTALLER64_TARGET}/install-prettier"
  # Lib / Prettier / Skip installation?
  export DEV_LIB_PRETTIER_SKIP='YES'
  # Lib / Prettier / Target
  export DEV_LIB_PRETTIER_TARGET="${DEV_PATH_LIB}/${DEV_ENV_PRETTIER_ID}"
  # Lib / Prettier / Configuration
  export DEV_LIB_PRETTIER_CFG="${DEV_PATH_ROOT}/.prettierrc.yaml"

  # Lint / Prettier / Format
  export DEV_LINT_PRETTIER_FORMAT='log'
  # Lint / Prettier / Report
  export DEV_LINT_PRETTIER_PATH_REPORT="${DEV_ENV_PRETTIER_PATH_LOGS}/${DEV_ENV_PRETTIER_ID}-lint.${DEV_LINT_PRETTIER_FORMAT}"
}

#
# Module parameters
#
# * Use .dev.env file to override values
#

# shellcheck disable=SC2154
{
  # Lint / Prettier / Target
  export DEV_LINT_PRETTIER_TARGET="${DEV_LINT_PRETTIER_TARGET:-${DEV_PATH_SRC}}"
}

#
# Locals
#
# * Use .local.env file or CICD variables to override values
#

# shellcheck disable=SC2154
{
  # Lib / Prettier / Command
  export DEV_LIB_PRETTIER_BIN="${DEV_LIB_PRETTIER_BIN:-}"
  if [[ -z "$DEV_LIB_PRETTIER_BIN" ]]; then
    DEV_LIB_PRETTIER_BIN="$(dev_bin64_lib_locate 'prettier')"
    if [[ -z "$DEV_LIB_PRETTIER_BIN" ]]; then
      DEV_LIB_PRETTIER_BIN="${DEV_LIB_PRETTIER_TARGET}/prettier"
      if [[ ! -x "${DEV_LIB_PRETTIER_BIN}" ]]; then
        DEV_LIB_PRETTIER_SKIP='NO'
      fi
    else
      DEV_LIB_PRETTIER_TARGET="$(dev_bin64_lib_basename "$DEV_LIB_PRETTIER_BIN")"
    fi
  fi
}
